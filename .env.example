# ──────────────────────────────────────────────────────────────────────
#  OmniRoute — environment variable set (reverse-proxy deployment)
#
#  When deploying via docker-compose.yml in Coolify you do NOT need this
#  file — secrets are generated automatically (SERVICE_* magic variables).
#  Use it when:
#    - deploying in Coolify as a single "Docker Image" application
#      (paste the contents into Environment Variables), or
#    - running standalone: docker compose --env-file .env
#
#  Full contract (2000+ lines, every variable):
#  https://github.com/diegosouzapw/OmniRoute/blob/main/.env.example
# ──────────────────────────────────────────────────────────────────────

# ═══ 1. REQUIRED SECRETS — set before first start ═══

# Dashboard session token signing.
# Generate: openssl rand -base64 48
JWT_SECRET=

# Encryption of provider API keys stored in SQLite.
# Generate: openssl rand -hex 32
API_KEY_SECRET=

# At-rest encryption of the whole SQLite database (recommended; empty = no encryption).
# Generate: openssl rand -hex 32
STORAGE_ENCRYPTION_KEY=
STORAGE_ENCRYPTION_KEY_VERSION=v1

# First dashboard login password — CHANGE IT, and after the first login
# set the final one in Dashboard → Settings → Security.
INITIAL_PASSWORD=CHANGEME

# Machine fingerprint salt — set a unique value per deployment.
MACHINE_ID_SALT=

# ═══ 2. NETWORK / REVERSE PROXY (Coolify/Traefik with TLS) ═══

PORT=20128

# MUST be true behind HTTPS — otherwise the browser won't send the session
# cookie and dashboard login will not work. On plain HTTP: false.
AUTH_COOKIE_SECURE=true

# Public URL of the instance (OAuth callbacks, links generated in the UI).
NEXT_PUBLIC_BASE_URL=https://omniroute.yourdomain.com

# Internal URL for sync jobs — keep loopback, even behind a proxy.
BASE_URL=http://localhost:20128

# Serving under a subpath (e.g. https://host/omniroute) — root by default.
# OMNIROUTE_BASE_PATH=/omniroute

# ═══ 3. SECURITY ═══

# Require an API key on the /v1/* proxy endpoints — true for public
# instances (create keys in Dashboard → API Keys).
REQUIRE_API_KEY=true

# Revealing full API key values in the UI — keep false.
ALLOW_API_KEY_REVEAL=false

# CORS — only if a separate frontend calls the API cross-origin.
# CORS_ALLOWED_ORIGINS=https://your-frontend.example.com

# ═══ 4. STORAGE ═══

# Data directory (SQLite, logs, backups) — mount as a volume.
DATA_DIR=/app/data
DISABLE_SQLITE_AUTO_BACKUP=false

# ═══ 5. REDIS (opt-in — rate-limiter backend) ═══
# Leave COMMENTED OUT without a running Redis (otherwise ioredis floods
# the logs with errors). With the compose from this repo: redis://redis:6379
REDIS_URL=redis://redis:6379

# ═══ 6. RUNTIME ═══

NODE_ENV=production

# Node heap limit (image default: 1024 MB). Raise BOTH together.
# OMNIROUTE_MEMORY_MB=2048
# NODE_OPTIONS=--max-old-space-size=2048

# TZ=Europe/Warsaw

# ═══ 7. LOGGING ═══

# APP_LOG_LEVEL=info          # debug | info | warn | error
# APP_LOG_FORMAT=text         # text | json
APP_LOG_TO_FILE=true
# APP_LOG_MAX_FILE_SIZE=50M
# APP_LOG_RETENTION_DAYS=7

# ═══ 8. PROVIDER KEYS ═══
# Preferred path: Dashboard → Providers → Add API Key (stored encrypted
# in the database). Env variables are an escape hatch for headless deployments:
# DEEPSEEK_API_KEY=
# NVIDIA_API_KEY=
# WINDSURF_API_KEY=
